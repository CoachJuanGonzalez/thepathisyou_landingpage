{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "AIRTABLE_API_KEY": "@airtable-api-key",
    "AIRTABLE_BASE_ID": "@airtable-base-id",
    "AIRTABLE_TABLE_NAME": "@airtable-table-name"
  }
}
